// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("DIRECT_URL")
}

model SystemSettings {
  key   String @id
  value String
}

model User {
  id              String           @id @default(cuid())
  uniqueCode      String           @unique
  role            String           // "UNIVERSITY_ADMIN", "HQ_COMMANDER", "SQUAD_COMMANDER"
  squadId         String?  
  squad           Squad?           @relation(fields: [squadId], references: [id])
  sessionToken    String?
  fullName        String?
  vkLink          String?
  accountRequests AccountRequest[]
}

model Squad {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  workType        String?
  workPlace       String?
  workSchedule    String?
  workPeriod      String?
  chatLink        String?
  fighterLimit    Int?
  users           User[]
  fighters        Fighter[]
  applications    Application[]
  accountRequests AccountRequest[]
  awardNominations AwardNomination[]
  incidentReports IncidentReport[]
  absenceLists    AbsenceList[]
}

model AccountRequest {
  id              String   @id @default(cuid())
  requestedRole   String
  squadId         String?
  squad           Squad?   @relation(fields: [squadId], references: [id])
  fullName        String
  faculty         String?
  studyGroup      String?
  course          Int?
  educationForm   String?
  phone           String?
  vkLink          String?
  requestedByUserId String
  requestedBy     User     @relation(fields: [requestedByUserId], references: [id])
  createdAt       DateTime @default(now())
}

model IdentifierRequest {
  id        String   @id @default(cuid())
  fullName  String
  vkLink    String
  userId    String
  status    String   @default("PENDING") // PENDING, PROCESSED
  newCode   String?
  createdAt DateTime @default(now())
}

model Fighter {
  id            String  @id @default(cuid())
  squadId       String
  squad         Squad   @relation(fields: [squadId], references: [id], onDelete: Cascade)
  position      String  // "Боец", "Командир", "Комиссар"
  fullName      String
  faculty       String
  studyGroup    String
  course        Int
  educationForm String  // "Бюджет", "Целевое", "Коммерческое"
  phone         String
  vkLink        String?
}

model Application {
  id            String   @id @default(cuid())
  squadId       String
  squad         Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  fullName      String
  faculty       String
  studyGroup    String
  course        Int
  educationForm String
  phone         String
  vkLink        String?
  createdAt     DateTime @default(now())
}

model AwardNomination {
  id                String          @id @default(cuid())
  squadId           String
  squad             Squad           @relation(fields: [squadId], references: [id])
  nominatedByUserId String
  status            String          @default("PENDING_HQ") // PENDING_HQ, PENDING_UNIVERSITY, APPROVED
  approvedByHqUserId String?
  targetAdminUserId  String?
  nominees          AwardNominee[]
  createdAt         DateTime        @default(now())
}

model AwardNominee {
  id            String          @id @default(cuid())
  nominationId  String
  nomination    AwardNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  fighterName   String
  fighterId     String?
  description   String
  approvedByHq  Boolean         @default(false)
  approvedByUni Boolean         @default(false)
}

model IncidentReport {
  id                String   @id @default(cuid())
  squadId           String
  squad             Squad    @relation(fields: [squadId], references: [id])
  reportedByUserId  String
  description       String
  involvedNames     String   // JSON array of fighter names
  createdAt         DateTime @default(now())
}

model AbsenceList {
  id                String         @id @default(cuid())
  squadId           String
  squad             Squad          @relation(fields: [squadId], references: [id])
  month             Int
  year              Int
  status            String         @default("DRAFT") // DRAFT, SENT
  sentByUserId      String?
  targetAdminUserId String?
  createdAt         DateTime       @default(now())
  entries           AbsenceEntry[]
}

model AbsenceEntry {
  id            String      @id @default(cuid())
  absenceListId String
  absenceList   AbsenceList @relation(fields: [absenceListId], references: [id], onDelete: Cascade)
  fighterId     String
  fighterName   String
  timeFrom      String
  dayFrom       Int
  timeTo        String
  dayTo         Int
}

